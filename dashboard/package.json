{
  "name": "team-dashboard",
  "version": "1.0.0",
  "description": "Dashboard и Telegram бот для управления AI агентами",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "bot": "node telegram-bot.js",
    "dev": "concurrently \"npm run start\" \"npm run bot\"",
    "install-deps": "npm install express axios node-telegram-bot-api"
  },
  "dependencies": {
    "express": "^4.18.2",
    "axios": "^1.6.0",
    "node-telegram-bot-api": "^0.64.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "keywords": ["ai", "agents", "dashboard", "telegram", "management"],
  "author": "OpenClaw Team",
  "license": "MIT"
}